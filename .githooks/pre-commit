#!/usr/bin/env sh
# Pre-commit hook: block commits containing sensitive data
# Compatible with Windows (GitHub Desktop), macOS, and Linux

# Block sensitive files
for f in data/config.json data/cookies.txt cookies.txt .env; do
    if git diff --cached --name-only | grep -qx "$f"; then
        echo "BLOCKED: Attempted to commit sensitive file: $f"
        echo "Remove it from staging: git reset HEAD $f"
        exit 1
    fi
done

# Scan staged content for API key / secret patterns (exclude hook scripts)
DIFF=$(git diff --cached -U0 -- ':!.githooks')

for pattern in \
    'AIza[0-9A-Za-z_-]\{35\}' \
    'sk-[0-9a-zA-Z]\{32,\}' \
    'hf_[0-9a-zA-Z]\{30,\}' \
    'Secure-1PSIDTS' \
    'Secure-3PSIDTS' \
    '\.youtube\.com.*TRUE'; do
    if echo "$DIFF" | grep -q "$pattern"; then
        echo "BLOCKED: Staged changes contain sensitive data matching: $pattern"
        echo "Review your changes and remove sensitive data before committing."
        exit 1
    fi
done

echo "Pre-commit check passed."
exit 0
