# Gemini API Key (required — set via dashboard or here)
GEMINI_API_KEY=

# Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Hugging Face token (optional — faster model downloads, no rate limits)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# YouTube cookies for age-restricted / bot-protected videos
YOUTUBE_COOKIES=

# Maximum concurrent processing jobs (default: 5)
MAX_CONCURRENT_JOBS=5

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5175

# GPU runtime (default: nvidia)
#   nvidia — NVIDIA GPU with CUDA (x86_64 only)
#   cpu    — CPU only (works on all platforms: x86_64, ARM64, Apple Silicon)
#
# Apple Silicon (M1/M2/M3/M4) users: set GPU_RUNTIME=cpu
# Or use: docker compose -f docker-compose.yml -f docker-compose.cpu.yml up --build
GPU_RUNTIME=nvidia

# Whisper model (auto-detected by default based on hardware)
# Options: tiny, base, small, medium, large-v3
# Auto-selection:
#   GPU >=6GB VRAM → large-v3 (best quality)
#   GPU >=3GB VRAM → medium
#   GPU <3GB VRAM  → small
#   CPU >=16GB RAM → medium
#   CPU >=8GB RAM  → small
#   CPU <8GB RAM   → base
# WHISPER_MODEL=large-v3
