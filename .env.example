# ──────────────────────────────────────────────────────────────
# ClippyMe — environment variables
# Copy to `.env` and fill in the values you care about.
# Most keys (Gemini, Deepgram, HF, cookies, Zernio) can also be
# configured from the dashboard Settings tab at runtime.
# ──────────────────────────────────────────────────────────────

# ── Gemini (required) ─────────────────────────────────────────
# Gemini API Key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model used for viral moment detection (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Retry behaviour when Gemini returns malformed JSON
# GEMINI_MAX_RETRIES=1
# GEMINI_RETRY_MODEL=gemini-2.5-pro

# ── Transcription ─────────────────────────────────────────────
# Provider used to transcribe the video audio track.
#   deepgram — cloud Nova-3 (default, fastest, multilingual)
#   whisper  — local Faster-Whisper (no API key, slower)
# TRANSCRIPTION_PROVIDER=deepgram

# Deepgram API Key — required when TRANSCRIPTION_PROVIDER=deepgram
# Get one at https://console.deepgram.com
DEEPGRAM_API_KEY=

# Deepgram tuning (all optional — defaults shown)
# DEEPGRAM_MODEL=nova-3
# DEEPGRAM_LANGUAGE=multi
# DEEPGRAM_KEYTERMS=              # comma-separated brand/jargon terms (Nova-3 only)
# DEEPGRAM_HTTP_TIMEOUT=600
# DEEPGRAM_MAX_RETRIES=3
# DEEPGRAM_MAX_FILE_MB=1900

# Whisper model (used when TRANSCRIPTION_PROVIDER=whisper, or as
# fallback when Deepgram fails). Auto-detected based on hardware.
# Options: tiny, base, small, medium, large-v3
# Auto-selection:
#   GPU >=6GB VRAM → large-v3 (best quality)
#   GPU >=3GB VRAM → medium
#   GPU <3GB VRAM  → small
#   CPU >=16GB RAM → medium
#   CPU >=8GB RAM  → small
#   CPU <8GB RAM   → base
# WHISPER_MODEL=large-v3

# Hugging Face token (optional — speeds up Whisper model downloads)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# ── YouTube download ──────────────────────────────────────────
# Inline cookies fallback (recommended: upload via dashboard instead)
YOUTUBE_COOKIES=

# ── Zernio social publishing (optional) ───────────────────────
# Only needed if you plan to publish clips directly to TikTok /
# Instagram / YouTube from the dashboard. Configure via the
# Settings tab — the API key is stored in data/config.json, not
# here, so it never lands in your shell history.
# ZERNIO_BASE_URL=https://zernio.com/api/v1
# ZERNIO_DEFAULT_TZ=Europe/Rome
# ZERNIO_HTTP_TIMEOUT=60
# ZERNIO_UPLOAD_TIMEOUT=600
# ZERNIO_MIN_GAP_SECONDS=5400      # SmartScheduler anti-collision gap

# ── Server ────────────────────────────────────────────────────
# Maximum concurrent processing jobs (default: 5)
MAX_CONCURRENT_JOBS=5

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5175

# GPU runtime (default: cpu — works on all platforms)
#   cpu    — CPU only (x86_64, ARM64, Apple Silicon)
#   nvidia — NVIDIA GPU with CUDA (x86_64 only)
#
# NVIDIA users: `docker compose -f docker-compose.yml -f docker-compose.gpu.yml up --build`
GPU_RUNTIME=cpu
